# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
CLIENT_URL=http://localhost:5173

# ── Phase 2: OpenRouter AI API ───────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# ── Phase 5: Voyage AI (for RAG Embeddings) ──────────────────────────────────
# Get yours at https://www.voyageai.com
VOYAGE_API_KEY=pa-your-key-here

# ── Phase 4: PostgreSQL (Docker Compose spins this up automatically) ──────────
DATABASE_URL=postgresql://hawkeye:hawkeye_password@localhost:5432/hawkeye_db

# ── Phase 3: Redis + BullMQ (Docker Compose spins this up automatically) ──────
REDIS_URL=redis://localhost:6379

# ── Phase 6: JWT Auth ─────────────────────────────────────────────────────────
# Change this to a long random string in production!
JWT_SECRET=hawkeye-super-secret-jwt-key-change-me-in-production
JWT_EXPIRES_IN=24h

INGEST_API_TOKEN=your-strong-secret-token
# Set to true to start the simulator, generate synthetic threats, and include system demo data in user views.
ENABLE_SIMULATOR=true
ENABLE_DEMO_USERS=false

# ── Phase 7: Telemetry delivery ─────────────────────────────────────────────
# Slack notifications
TELEMETRY_SLACK_ENABLED=true
TELEMETRY_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/replace/me
TELEMETRY_SLACK_CHANNEL=#security-alerts

# SMTP notifications
TELEMETRY_SMTP_ENABLED=true
TELEMETRY_SMTP_HOST=smtp.example.com
TELEMETRY_SMTP_PORT=587
TELEMETRY_SMTP_USER=mailer@example.com
TELEMETRY_SMTP_PASSWORD=replace-me
TELEMETRY_SMTP_FROM=security@example.com
TELEMETRY_SMTP_TO=secops@example.com

# PagerDuty incidents
TELEMETRY_PAGERDUTY_ENABLED=true
TELEMETRY_PAGERDUTY_ROUTING_KEY=replace-me
TELEMETRY_PAGERDUTY_SERVICE_ID=replace-me

# Generic webhook notifications
TELEMETRY_WEBHOOK_ENABLED=true
TELEMETRY_WEBHOOK_URL=https://example.com/hawkeye/telemetry
TELEMETRY_WEBHOOK_SECRET=replace-me

# Optional app metadata used in delivery payloads
APP_BASE_URL=http://localhost:5173
# ── Default users (change passwords in production) ────────────────────────────
# admin@hawkeye.ai   / admin123   → ADMIN role
# analyst@hawkeye.ai / analyst123 → ANALYST role
# viewer@hawkeye.ai  / viewer123  → VIEWER role
