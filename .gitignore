# ═════════════════════════════════════════════════════════════════════════════
# HawkEye AI - Global .gitignore
# ═════════════════════════════════════════════════════════════════════════════
# This file prevents sensitive and unnecessary files from being committed to Git

# ─────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT & SECRETS
# ─────────────────────────────────────────────────────────────────────────────
# CRITICAL: Never commit environment files with real credentials
.env
.env.local
.env.*.local
.env.production.local
.env.test.local

# Secrets and credentials
.secrets/
secrets.json
credentials.json
*.key
*.pem
.ssh/

# ─────────────────────────────────────────────────────────────────────────────
# DEPENDENCIES & NODE
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
*.npm
.npm/
.eslintcache
.node_repl_history
*.tgz
.yarn-integrity

# ─────────────────────────────────────────────────────────────────────────────
# BUILD & COMPILATION OUTPUT
# ─────────────────────────────────────────────────────────────────────────────
dist/
build/
.next/
out/
.cache/
.turbo/
.vite/

# TypeScript
*.tsbuildinfo
.tsc-build/

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE & PRISMA
# ─────────────────────────────────────────────────────────────────────────────
/generated/prisma
.prisma/
prisma/migrations/
*.db
*.sqlite
*.sqlite3
dump.rdb
*.rdb

# ─────────────────────────────────────────────────────────────────────────────
# IDE & EDITOR
# ─────────────────────────────────────────────────────────────────────────────
.idea/
.vscode/
.vscode-test/
*.code-workspace
*.swp
*.swo
*~
.DS_Store
Thumbs.db
.sublime-workspace
.sublime-project
*.iml
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.history
.ionide/
.AppleDouble
.LSOverride
._*

# ─────────────────────────────────────────────────────────────────────────────
# TESTING & COVERAGE
# ─────────────────────────────────────────────────────────────────────────────
coverage/
.nyc_output/
.coverage
htmlcov/
.pytest_cache/
test-results/
junit.xml

# ─────────────────────────────────────────────────────────────────────────────
# LOGS & TEMPORARY FILES
# ─────────────────────────────────────────────────────────────────────────────
logs/
*.log
*.log*
pids/
*.pid
*.seed
*.pid.lock
tmp/
temp/
tempfile.txt
.temp/

# ─────────────────────────────────────────────────────────────────────────────
# OS-SPECIFIC FILES
# ─────────────────────────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
*.swp
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory

# ─────────────────────────────────────────────────────────────────────────────
# RUNTIME & PROCESS MANAGEMENT
# ─────────────────────────────────────────────────────────────────────────────
.pm2/
.pm2logs/
pids/

# ─────────────────────────────────────────────────────────────────────────────
# DOCKER & CONTAINERS
# ─────────────────────────────────────────────────────────────────────────────
# Keep docker-compose.yml but ignore local overrides
docker-compose.override.yml
docker-compose.*.yml
.dockerignore

# ─────────────────────────────────────────────────────────────────────────────
# BACKUP & ARCHIVE FILES
# ─────────────────────────────────────────────────────────────────────────────
*.bak
*.backup
*.swp
*.swo
*~
*.tmp
*.orig
*.rej

# ─────────────────────────────────────────────────────────────────────────────
# PACKAGE MANAGER LOCK FILES (Optional - uncomment if you want to include)
# Keep package-lock.json and yarn.lock to ensure reproducible installs
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ─────────────────────────────────────────────────────────────────────────────
# RUNTIME ARTIFACTS
# ─────────────────────────────────────────────────────────────────────────────
*.pem
*.jks
*.p12
*.pfx

# ─────────────────────────────────────────────────────────────────────────────
# PROJECT-SPECIFIC IGNORES
# ─────────────────────────────────────────────────────────────────────────────
# Any local development scripts
scripts/local-*/
local-scripts/

# Postman environment files with secrets
postman/environments/*.local.json

# ═════════════════════════════════════════════════════════════════════════════
